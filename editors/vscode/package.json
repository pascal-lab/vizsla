{
  "name": "vizsla-vscode",
  "displayName": "Vizsla LSP",
  "description": "Language support for Verilog and SystemVerilog powered by the Vizsla language server.",
  "version": "0.0.1",
  "publisher": "vizsla",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/roife/vizsla"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "verilog",
        "aliases": [
          "Verilog"
        ],
        "extensions": [
          ".v",
          ".vh"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "systemverilog",
        "aliases": [
          "SystemVerilog"
        ],
        "extensions": [
          ".sv",
          ".svh",
          ".svi"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "verilog",
        "scopeName": "source.verilog",
        "path": "./syntaxes/verilog.tmLanguage.json"
      },
      {
        "language": "systemverilog",
        "scopeName": "source.systemverilog",
        "path": "./syntaxes/systemverilog.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Vizsla Language Server",
      "properties": {
        "vizsla.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        },
        "vizsla.server.command": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Override command used to launch the Vizsla language server. Leave empty to use the bundled binary."
        },
        "vizsla.server.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Arguments passed before any additional arguments when a custom command is provided."
        },
        "vizsla.server.cwd": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Working directory for the Vizsla language server process. Defaults to the first workspace folder."
        },
        "vizsla.server.additionalArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional arguments appended when launching the Vizsla language server."
        },
        "vizsla.diagnostics": {
          "type": "object",
          "default": {
            "enable": true,
            "parse": {
              "enable": true
            },
            "semantic": {
              "enable": true
            },
            "slang": {
              "warnings": [],
              "rules": []
            }
          },
          "markdownDescription": "Controls Vizsla diagnostics. Use this object for advanced diagnostic filtering and severity overrides.",
          "properties": {
            "enable": {
              "type": "boolean",
              "default": true,
              "description": "Enable all Vizsla diagnostics."
            },
            "update": {
              "type": "string",
              "enum": [
                "onSave",
                "onType"
              ],
              "default": "onSave",
              "markdownDescription": "Controls when diagnostics are refreshed. `onSave` avoids running expensive diagnostics on every edit; `onType` refreshes diagnostics after document changes."
            },
            "parse": {
              "type": "object",
              "default": {
                "enable": true
              },
              "description": "Controls syntax and parse diagnostics.",
              "properties": {
                "enable": {
                  "type": "boolean",
                  "default": true,
                  "description": "Enable syntax and parse diagnostics."
                }
              },
              "additionalProperties": false
            },
            "semantic": {
              "type": "object",
              "default": {
                "enable": true
              },
              "description": "Controls compilation and semantic diagnostics.",
              "properties": {
                "enable": {
                  "type": "boolean",
                  "default": true,
                  "description": "Enable compilation and semantic diagnostics."
                }
              },
              "additionalProperties": false
            },
            "slang": {
              "type": "object",
              "default": {
                "warnings": [],
                "rules": []
              },
              "description": "Controls diagnostics produced by slang.",
              "properties": {
                "warnings": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": [],
                  "markdownDescription": "slang warning options, equivalent to command-line warning names such as `default`, `everything`, `none`, `error`, `no-<name>`, or `error=<name>`."
                },
                "rules": {
                  "type": "array",
                  "default": [],
                  "markdownDescription": "Rules that filter or override diagnostic severities. Supported selectors: `code:<subsystem>:<code>`, `option:<name>`, `group:<name>`, `source:parse`, `source:semantic`.",
                  "items": {
                    "type": "object",
                    "required": [
                      "selector",
                      "severity"
                    ],
                    "properties": {
                      "selector": {
                        "type": "string",
                        "pattern": "^(code:[0-9]+:[0-9]+|option:.+|group:.+|source:(parse|semantic))$",
                        "markdownDescription": "Diagnostic selector. Examples: `code:1:2`, `option:unconnected-port`, `group:default`, `source:semantic`."
                      },
                      "severity": {
                        "type": "string",
                        "enum": [
                          "ignore",
                          "info",
                          "warning",
                          "error",
                          "fatal"
                        ],
                        "description": "Severity to apply when this rule matches. Use ignore to hide the diagnostic."
                      },
                      "force": {
                        "type": "boolean",
                        "default": false,
                        "description": "Reserved for future support for overriding in-source diagnostic pragmas."
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    },
    "commands": [
      {
        "command": "vizsla.showOutput",
        "title": "Vizsla: Show Language Server Output"
      },
      {
        "command": "vizsla.restartServer",
        "title": "Vizsla: Restart Language Server"
      },
      {
        "command": "vizsla.showServerVersion",
        "title": "Vizsla: Show Server Version"
      }
    ]
  },
  "scripts": {
    "bundle": "esbuild src/extension.ts --bundle --platform=node --target=node22 --format=cjs --external:vscode --outfile=dist/extension.js",
    "clean": "tsx scripts/clean.ts",
    "typecheck": "tsc -p . --noEmit",
    "compile": "npm run clean && npm run typecheck && npm run bundle",
    "test": "npm run compile && node --import tsx --test \"test/**/*.test.ts\"",
    "package": "npm run compile && tsx scripts/package.ts",
    "package:darwin-arm64": "npm run compile && tsx scripts/package.ts darwin-arm64",
    "package:darwin-x64": "npm run compile && tsx scripts/package.ts darwin-x64",
    "package:linux-x64": "npm run compile && tsx scripts/package.ts linux-x64",
    "package:linux-arm64": "npm run compile && tsx scripts/package.ts linux-arm64",
    "package:win32-x64": "npm run compile && tsx scripts/package.ts win32-x64",
    "package:win32-arm64": "npm run compile && tsx scripts/package.ts win32-arm64",
    "install-extension": "code --install-extension vizsla-vscode-*.vsix"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "22.15.1",
    "@types/vscode": "1.101.0",
    "@vscode/vsce": "^3.6.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3"
  }
}
