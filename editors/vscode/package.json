{
  "name": "vide-ide",
  "displayName": "Vide - Verilog/SystemVerilog Coding IDE",
  "description": "%extension.description%",
  "version": "0.1.7",
  "publisher": "pascal-lab",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/pascal-lab/vide"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "languages": [
      {
        "id": "verilog",
        "aliases": [
          "Verilog"
        ],
        "extensions": [
          ".v",
          ".vh"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "systemverilog",
        "aliases": [
          "SystemVerilog"
        ],
        "extensions": [
          ".sv",
          ".svh",
          ".svi"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "verilog",
        "scopeName": "source.verilog",
        "path": "./syntaxes/verilog.tmLanguage.json"
      },
      {
        "language": "systemverilog",
        "scopeName": "source.systemverilog",
        "path": "./syntaxes/systemverilog.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "*.read:verilog": {
            "bold": true
          },
          "*.write:verilog": {
            "bold": true,
            "underline": true
          },
          "*.read:systemverilog": {
            "bold": true
          },
          "*.write:systemverilog": {
            "bold": true,
            "underline": true
          }
        }
      }
    },
    "configuration": {
      "title": "Vide",
      "properties": {
        "vide.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "%configuration.trace.server.description%"
        },
        "vide.server.command": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "%configuration.server.command.description%"
        },
        "vide.server.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%configuration.server.args.description%"
        },
        "vide.server.cwd": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "%configuration.server.cwd.description%"
        },
        "vide.server.additionalArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%configuration.server.additionalArgs.description%"
        },
        "vide.qihe.command": {
          "type": "string",
          "default": "qihe",
          "description": "%configuration.qihe.command.description%"
        },
        "vide.qihe.autoConfigureArgsFromManifest": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.qihe.autoConfigureArgsFromManifest.description%"
        },
        "vide.qihe.compileArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%configuration.qihe.compileArgs.description%"
        },
        "vide.qihe.runArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "-g",
            "std"
          ],
          "description": "%configuration.qihe.runArgs.description%"
        },
        "vide.files.excludeDirs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "%configuration.files.excludeDirs.markdownDescription%"
        },
        "vide.files.watcher": {
          "type": "string",
          "enum": [
            "client",
            "notify",
            "server"
          ],
          "default": "client",
          "enumDescriptions": [
            "%configuration.files.watcher.enum.client%",
            "%configuration.files.watcher.enum.notify%",
            "%configuration.files.watcher.enum.server%"
          ],
          "description": "%configuration.files.watcher.description%"
        },
        "vide.workspace.auto.reload": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.workspace.auto.reload.description%"
        },
        "vide.scope.visibility": {
          "type": "string",
          "enum": [
            "private",
            "public"
          ],
          "default": "private",
          "description": "%configuration.scope.visibility.description%"
        },
        "vide.formatter.provider": {
          "type": "string",
          "enum": [
            "verible"
          ],
          "default": "verible",
          "enumDescriptions": [
            "%configuration.formatter.provider.enum.verible%"
          ],
          "description": "%configuration.formatter.provider.description%"
        },
        "vide.formatter.path": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "%configuration.formatter.path.description%"
        },
        "vide.formatter.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--failsafe_success=false"
          ],
          "description": "%configuration.formatter.args.description%"
        },
        "vide.formatting.on.enter": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.formatting.on.enter.description%"
        },
        "vide.formatting.in.comments": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.formatting.in.comments.description%"
        },
        "vide.formatting.indent.width": {
          "type": "integer",
          "minimum": 0,
          "default": 4,
          "description": "%configuration.formatting.indent.width.description%"
        },
        "vide.inlayHints.port.connection.enable": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.inlayHints.port.connection.enable.description%"
        },
        "vide.inlayHints.parameter.assignment.enable": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.inlayHints.parameter.assignment.enable.description%"
        },
        "vide.inlayHints.end.structure.enable": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.inlayHints.end.structure.enable.description%"
        },
        "vide.lens.instantiations.enable": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.lens.instantiations.enable.description%"
        },
        "vide.semantic.tokens.port.clk.rst.enable": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.semantic.tokens.port.clk.rst.enable.description%"
        },
        "vide.semantic.tokens.port.input.output.enable": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.semantic.tokens.port.input.output.enable.description%"
        },
        "vide.diagnostics.enable": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.diagnostics.enable.description%"
        },
        "vide.diagnostics.update": {
          "type": "string",
          "enum": [
            "onSave",
            "onType"
          ],
          "default": "onSave",
          "markdownDescription": "%configuration.diagnostics.update.markdownDescription%"
        },
        "vide.diagnostics.parse.enable": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.diagnostics.parse.enable.description%"
        },
        "vide.diagnostics.semantic.enable": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.diagnostics.semantic.enable.description%"
        },
        "vide.diagnostics.slang.warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "%configuration.diagnostics.slang.warnings.markdownDescription%"
        },
        "vide.diagnostics.slang.rules": {
          "type": "array",
          "default": [],
          "markdownDescription": "%configuration.diagnostics.slang.rules.markdownDescription%",
          "items": {
            "type": "object",
            "required": [
              "selector",
              "severity"
            ],
            "properties": {
              "selector": {
                "type": "string",
                "pattern": "^(code:[0-9]+:[0-9]+|option:.+|group:.+|source:(parse|semantic))$",
                "markdownDescription": "%configuration.diagnostics.slang.rules.selector.markdownDescription%"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "ignore",
                  "info",
                  "warning",
                  "error",
                  "fatal"
                ],
                "description": "%configuration.diagnostics.slang.rules.severity.description%"
              },
              "force": {
                "type": "boolean",
                "default": false,
                "description": "%configuration.diagnostics.slang.rules.force.description%"
              }
            },
            "additionalProperties": false
          }
        },
        "vide.signature.help.params.only": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.signature.help.params.only.description%"
        }
      }
    },
    "commands": [
      {
        "command": "vide.showOutput",
        "title": "%command.showOutput.title%"
      },
      {
        "command": "vide.restartServer",
        "title": "%command.restartServer.title%"
      },
      {
        "command": "vide.showServerVersion",
        "title": "%command.showServerVersion.title%"
      },
      {
        "command": "vide.reloadWorkspace",
        "title": "%command.reloadWorkspace.title%"
      },
      {
        "command": "vide.showStatus",
        "title": "%command.showStatus.title%"
      },
      {
        "command": "vide.runQiheAnalysis",
        "title": "%command.runQiheAnalysis.title%",
        "icon": "$(beaker)"
      },
      {
        "command": "vide.profileDiagnostics",
        "title": "%command.profileDiagnostics.title%",
        "icon": "$(pulse)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vide.runQiheAnalysis",
          "when": "resourceLangId == verilog || resourceLangId == systemverilog",
          "group": "navigation@10"
        }
      ]
    }
  },
  "scripts": {
    "bundle": "esbuild src/extension.ts --bundle --platform=node --target=node22 --format=cjs --external:vscode --outfile=dist/extension.js && npm run copy-speedscope",
    "clean": "tsx scripts/clean.ts",
    "copy-speedscope": "tsx scripts/copy-speedscope-assets.ts",
    "typecheck": "tsc -p . --noEmit",
    "compile": "npm run clean && npm run typecheck && npm run bundle",
    "test": "npm run compile && node --import tsx --test \"test/**/*.test.ts\"",
    "package:debug": "npm run compile && tsx scripts/package.ts --debug",
    "package:alpine-arm64": "npm run compile && tsx scripts/package.ts alpine-arm64",
    "package:alpine-x64": "npm run compile && tsx scripts/package.ts alpine-x64",
    "package:darwin-arm64": "npm run compile && tsx scripts/package.ts darwin-arm64",
    "package:darwin-x64": "npm run compile && tsx scripts/package.ts darwin-x64",
    "package:linux-x64": "npm run compile && tsx scripts/package.ts linux-x64",
    "package:linux-arm64": "npm run compile && tsx scripts/package.ts linux-arm64",
    "package:win32-x64": "npm run compile && tsx scripts/package.ts win32-x64",
    "package:win32-arm64": "npm run compile && tsx scripts/package.ts win32-arm64",
    "install-extension": "tsx scripts/install-extension.ts"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "22.15.1",
    "@types/vscode": "1.101.0",
    "@vscode/l10n-dev": "^0.0.35",
    "@vscode/vsce": "^3.6.2",
    "esbuild": "^0.28.0",
    "speedscope": "1.25.0",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3"
  }
}
