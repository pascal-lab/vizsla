# rename
module_ref -> renamed_child
  module renamed_child(input wire a, output wire y);
  renamed_child u_child(.a(sig), .y());
udp_ref -> renamed_udp
  primitive renamed_udp(out, in);
  renamed_udp u_udp(sig, clk);
port_ref -> renamed_a
  module child(input wire renamed_a, output wire y);
  child u_child(.renamed_a(sig), .y());
sig_ref -> renamed_sig
  wire renamed_sig;
  child u_child(.a(renamed_sig), .y());
  udp_and u_udp(renamed_sig, clk);
  renamed_sig = t_in;
  (clk => renamed_sig) = T_SETUP;
  do_task(renamed_sig);
  renamed_sig = T_SETUP;
  renamed_sig = u_child.y;
  renamed_sig = g_loop[0].lane;
genvar_ref -> renamed_i
  genvar renamed_i;
  for (renamed_i = 0; renamed_i < 1; renamed_i = renamed_i + 1) begin : g_loop
specparam_ref -> renamed_T_SETUP
  specparam renamed_T_SETUP = 1;
  (clk => sig) = renamed_T_SETUP;
  sig = renamed_T_SETUP;
task_ref -> renamed_task
  task automatic renamed_task;
  renamed_task(sig);
instance_ref -> renamed_u_child
  child renamed_u_child(.a(sig), .y());
  sig = renamed_u_child.y;
generate_ref -> renamed_g_loop
  for (i = 0; i < 1; i = i + 1) begin : renamed_g_loop
  sig = renamed_g_loop[0].lane;
block_ref -> renamed_blk
  initial begin : renamed_blk
  disable renamed_blk;
config_def -> renamed_cfg
  config renamed_cfg;

