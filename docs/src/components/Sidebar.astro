---
import StarlightUtilsSidebar from '@lorenzo_lewis/starlight-utils/components/Sidebar.astro';

const navLinks = Astro.locals.starlightUtils.navLinks ?? [];
const route = Astro.locals.starlightRoute;
const isEnglish = route.locale === 'en';
const navLabel = isEnglish ? 'Site navigation' : '站点导航';
---

{
  navLinks.length > 0 && (
    <section class="vide-sidebar-site-nav" aria-labelledby="vide-sidebar-site-nav-title">
      <p id="vide-sidebar-site-nav-title">{navLabel}</p>
      <ul>
        {navLinks.map((entry) => (
          <li>
            <a href={entry.href} {...entry.attrs} aria-current={entry.isCurrent && 'page'}>
              {entry.label}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}

<StarlightUtilsSidebar />

<style>
  .vide-sidebar-site-nav {
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .vide-sidebar-site-nav p {
    margin: 0 0 0.5rem;
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-xs);
    font-weight: 600;
  }

  .vide-sidebar-site-nav ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .vide-sidebar-site-nav a {
    display: block;
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 0.375rem;
    padding: 0.5rem 0.625rem;
    color: var(--sl-color-gray-2);
    background: var(--sl-color-bg-nav);
    font-size: var(--sl-text-sm);
    line-height: 1.3;
    text-decoration: none;
  }

  .vide-sidebar-site-nav a:hover,
  .vide-sidebar-site-nav a:focus {
    border-color: var(--sl-color-text-accent);
    color: var(--sl-color-white);
  }

  .vide-sidebar-site-nav a[aria-current='page'] {
    border-color: var(--sl-color-text-accent);
    color: var(--sl-color-white);
    font-weight: 600;
  }

  @media (min-width: 58rem) {
    .vide-sidebar-site-nav {
      display: none;
    }
  }
</style>
