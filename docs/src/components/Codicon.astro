---
import "@vscode/codicons/dist/codicon.css";

interface Props {
  name: string;
  modifier?: "spin";
  label?: string;
}

const { name, modifier, label } = Astro.props;
const iconClasses = [
  "codicon",
  `codicon-${name}`,
  modifier ? `codicon-modifier-${modifier}` : undefined,
];
const accessibility = label ? { role: "img", "aria-label": label } : { "aria-hidden": "true" };
---

<span class="vide-codicon" {...accessibility}>
  <span class:list={iconClasses} aria-hidden="true"></span>
</span>

<style>
  .vide-codicon {
    display: inline-flex;
    align-items: center;
    vertical-align: -0.125em;
    line-height: 1;
  }

  .codicon {
    font-size: 1em;
    line-height: 1;
  }
</style>
