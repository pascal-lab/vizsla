---
import HomepageFeatureCarousel from './HomepageFeatureCarousel.astro';
import { normalizeHomepageLocale, type HomepageLocale } from '../data/homepage';

interface Props {
  locale?: HomepageLocale;
}

const locale = normalizeHomepageLocale(Astro.props.locale);
const heading =
  locale === 'en'
    ? `Make <span class="vide-feature__accent"><strong>hardware design</strong></span><br />feel as fluid as developing software`
    : `让<span class="vide-feature__accent"><strong>硬件设计</strong></span><br />像开发软件一样<wbr /><span class="vide-feature__nowrap">丝滑顺手</span>`;
---

<section class="vide-feature">
  <h2 set:html={heading} />
  <HomepageFeatureCarousel locale={locale} />
</section>

<style>
  .vide-feature {
    margin-block: clamp(2rem, 6vw, 3rem);
  }

  .vide-feature h2 {
    max-width: 20ch;
    margin-block: 0.75rem clamp(2.75rem, 5vw, 4.5rem);
    color: var(--sl-color-white);
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: 0;
    line-height: 1.4;
  }

  .vide-feature__accent {
    color: var(--vide-accent);
  }

  .vide-feature__nowrap {
    white-space: nowrap;
  }
</style>
